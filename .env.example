TELEGRAM_BOT_TOKEN=your-bot-token-from-@BotFather
TELEGRAM_CHAT_ID=your-numeric-chat-id
# To notify multiple recipients with the same bot, add more chat_ids under
# notify.telegram.chat_ids in config.yaml (each entry can reference its own
# env var, or be a literal chat id).

# The Target check uses a headless browser (~2 GB RAM). On a 1 GB box,
# uncomment the next line to skip it (Canon + Best Buy still run):
# DISABLE_BROWSER_TIER=1
